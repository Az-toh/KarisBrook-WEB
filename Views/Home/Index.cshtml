                                                    <i class="fa fa-angle-right"></i>
                                                </button>
                                            </div>
                                            <div class='asd_outer'>
                                                <div id='asd_strip' class='asd_strip'>
                                                   @foreach (var product in Model.BestSellers)
{
    <div class="asd_card">
        <div class="single-product">
            <div class="product-img">
                <a href="@Url.Action("Details", "Products", new { id = product.Id })">
                    <img class="primary-img" title="@product.Name" src="~@product.ImagePath" alt="@product.Name">
                </a>    
            </div>
            <div class="product-description">
                <h5><a href="@Url.Action("Details", "Products", new { id = product.Id })">@product.Name</a></h5>
                <div class="price-box">
                    @if (product.OldPrice.HasValue)
                    {
                        <span class="price">@product.Price ₽</span>
                        <span class="old-price">@product.OldPrice ₽</span>
                    }
                    else
                    {
                        <span class="price">@product.Price ₽</span>
                    }
                </div>
                <span class="rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round(product.Rating))
                        {
                            <i class="fa fa-star"></i>
                        }
                        else
                        {
                            <i class="fa fa-star-o"></i>
                        }
                    }
                </span>
            </div>
            <div class="product-action">
                <div class="button-group">
                    <!-- КНОПКА "В КОРЗИНУ" УБРАНА -->
                    <div class="product-button-2">
                        <a href="#" data-toggle="tooltip" title="Вишлист"><i class="fa fa-heart-o"></i></a>
                        <a href="#" data-toggle="tooltip" title="Сравнение"><i class="fa fa-signal"></i></a>
                        <a href="@Url.Action("Details", "Products", new { id = product.Id })" class="modal-view" title="Подробнее"><i class="fa fa-search-plus"></i></a>
                    </div>
                </div>
            </div>												
        
    
}>
                                                            </div>
                                                        </div>
