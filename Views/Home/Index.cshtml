@model KarisBrook.Models.HomeViewModel

@{
    ViewData["Title"] = "Главная - KarisBrook";
}

<!-- Category slider area start -->
<div class="category-slider-area">
    <div class="container">
        <div class="row">
            <div class="col-md-10">
                <div class="slider-area">
                    <div class="bend niceties preview-1">
                        <div id="ensign-nivoslider" class="slides">
                            <img src="~/sliders/bg1.jpg" alt="KarisBrook" title="#slider-direction-1" />
                            <img src="~/sliders/bg2.jpg" alt="KarisBrook" title="#slider-direction-2" />
                            <img src="~/sliders/bg3.jpg" alt="KarisBrook" title="#slider-direction-3" />
                        </div>
                        <!-- direction 1 -->
                        <div id="slider-direction-1" class="t-lfr slider-direction">
                            <div class="slider-progress"></div>
                            <div class="layer-1-1 ">
                                <h1 class="title1">СОЛНЦЕЗАШИТНЫЕ ОЧКИ KNOX</h1>
                            </div>
                            <div class="layer-1-2">
                                <p class="title2">Смотри на жизнь ясно</p>
                            </div>
                            <div class="layer-1-3">
                                <h2 class="title3">900₽</h2>
                            </div>
                            <div class="layer-1-4">
                                <a href="#" class="title4">Купить сейчас</a>
                            </div>
                        </div>
                        <!-- direction 2 -->
                        <div id="slider-direction-2" class="slider-direction">
                            <div class="slider-progress"></div>
                            <div class="layer-2-1">
                                <h1 class="title1">BENCHGRADE CAPTOE BAIMORAI</h1>
                            </div>
                            <div class="layer-2-3">
                                <a href="#" class="title3">Купить сейчас</a>
                            </div>
                        </div>
                        <!-- direction 3 -->
                        <div id="slider-direction-3" class="slider-direction">
                            <div class="slider-progress"></div>
                            <div class="layer-3-1">
                                <h2 class="title1">AME DE THE VERT</h2>
                            </div>
                            <div class="layer-3-2">
                                <h1 class="title2">Особеное предложение</h1>
                            </div>
                            <div class="layer-3-3">
                                <p class="title3">Ame de Thé Vert (душа зеленого чая) - зеленый ароматический одеколон для мужчин и женщин.</p>
                            </div>
                            <div class="layer-3-4">
                                <a href="#" class="title4">Купить сейчас</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Category slider area End -->

