@{
    ViewData["Title"] = "Ошибка";
}

<div class="container">
    <h2>Произошла ошибка при оформлении заказа</h2>
    <p>Пожалуйста, попробуйте ещё раз или свяжитесь с поддержкой.</p>
    <p>Код ошибки: @ViewData["ErrorMessage"]</p>
    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">На главную</a>
    <a href="@Url.Action("Checkout", "Order")" class="btn btn-secondary">Вернуться к оформлению</a>
</div>