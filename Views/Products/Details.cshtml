@model KarisBrook.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container">
    <div class="row">
        <div class="col-md-6">
            <img src="~@Model.ImagePath" class="img-fluid" alt="@Model.Name">
        </div>
        <div class="col-md-6">
            <h2>@Model.Name</h2>
            <p><strong>Бренд:</strong> @Model.Brand?.Name</p>
            <p><strong>Категория:</strong> @Model.Category?.Name</p>
            <p><strong>Цена:</strong> @Model.Price ₽</p>
            @if (Model.OldPrice.HasValue)
            {
                <p><s>@Model.OldPrice ₽</s> <span class="text-danger">Скидка!</span></p>
            }
            <p>@Model.Description</p>

            <!-- ФОРМА ДЛЯ ДОБАВЛЕНИЯ В КОРЗИНУ -->
            <form method="post" asp-action="Add" asp-controller="Cart" asp-route-productId="@Model.Id">
                <div class="form-group">
                    <label for="quantity">Количество</label>
                    <input type="number" name="quantity" value="1" min="1" class="form-control" style="width:100px; display:inline-block;" />
                </div>
                <button type="submit" class="btn btn-primary">Добавить в корзину</button>
                <a href="@Url.Action("List")" class="btn btn-secondary">Назад к каталогу</a>
            </form>
        </div>
    </div>
</div>